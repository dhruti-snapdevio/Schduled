{
  "name": "schduled",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "concurrently -n next,worker -c blue,yellow \"next dev --turbopack\" \"tsx --watch scripts/worker.ts\"",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "worker": "tsx --watch scripts/worker.ts",
    "worker:start": "tsx scripts/worker.ts",
    "db:local": "tsx scripts/dev-db.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:reset": "tsx db/reset.ts && pnpm db:migrate",
    "make:admin": "tsx scripts/make-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-email/render": "^2.0.8",
    "better-auth": "^1.6.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.2",
    "googleapis": "^173.0.0",
    "ical-generator": "^11.0.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "nprogress": "^0.2.0",
    "pg-boss": "^12.19.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.0",
    "react-hook-form": "^7.79.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/nprogress": "^0.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "embedded-postgres": "18.4.0-beta.17",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  }
}
