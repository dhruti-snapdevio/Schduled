# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/saas_starter

# Better Auth — must be 32+ characters
APP_SECRET=change-me-to-a-random-32-char-secret!!

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="My SaaS App <no-reply@example.com>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for OAuth tokens — generate with: openssl rand -hex 32
ENCRYPT_KEY=

# Zoom OAuth (create app at marketplace.zoom.us)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# File storage driver
# 'local' → saves to public/uploads/ (served at /uploads/) — no credentials needed, perfect for dev
# 's3'    → uploads to Cloudflare R2 / AWS S3 / MinIO — fill in S3_* vars below
STORAGE_DRIVER=local

# S3/R2 credentials — only needed when STORAGE_DRIVER=s3
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://assets.schduled.com
