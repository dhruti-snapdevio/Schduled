# PostgreSQL connection string
# - Manual/Node install → host is "localhost".
# - Docker Compose, bundled Postgres (docker-compose.yml) → host is "postgres"
#   (the service name below) and must match POSTGRES_USER/POSTGRES_PASSWORD/
#   POSTGRES_DB.
# - Docker Compose, your own database (docker-compose.external-db.yml) → host
#   is your database's real hostname (managed service or your own instance).
#   POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB below don't apply — leave them.
DATABASE_URL=postgresql://user:password@localhost:5432/schduled

# Only used by docker-compose.yml (the bundled-Postgres file), to create that
# container's initial user/db — keep these in sync with the DATABASE_URL above
# when using it. Not read by the app itself. Ignored by the manual/Node path
# and by docker-compose.external-db.yml.
POSTGRES_USER=schduled
POSTGRES_PASSWORD=change-me
POSTGRES_DB=schduled

NODE_ENV=development

# Postgres connection pool size (per web replica). Do the math before scaling
# to multiple replicas: replicas × DB_POOL_MAX must stay under your
# database's max_connections.
DB_POOL_MAX=20

# Better Auth — must be 32+ characters
APP_SECRET=change-me-to-a-random-32-char-secret!!

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Schduled <no-reply@example.com>"
EMAIL_WEBHOOK_SECRET=

# First-run admin bootstrap — this email is auto-promoted to admin the moment
# it signs up (checked once, at account creation; leave blank to skip and use
# `pnpm make:admin <email>` manually after signup instead)
INITIAL_ADMIN_EMAIL=

# Gates ALL new-account creation (password sign-up, magic link first-use,
# Google first-login) — on by default so nothing changes unless you opt in.
# Recommended for self-hosting: set to 'false' from day one, alongside
# INITIAL_ADMIN_EMAIL above — that account can always sign up regardless of
# this setting, so there's no "open window" between deploy and closing signup.
SIGNUP_ENABLED=true

# Marketing landing page at "/" — on by default. Set to 'false' for internal/
# team deployments that don't want a public marketing page; "/" then
# redirects to "/login" instead. Booking + legal pages are unaffected.
NEXT_PUBLIC_LANDING_ENABLED=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for OAuth tokens — generate with: openssl rand -hex 32
ENCRYPT_KEY=

# Zoom OAuth (create app at marketplace.zoom.us)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Address autocomplete geocoder (in-person location field)
# Leave everything blank to use the free, keyless Photon (OpenStreetMap) provider.
# Set a key below for richer village/street/building coverage — the provider is
# auto-detected (Mapbox > Google > Photon), or pin it with GEOCODER_PROVIDER.
# GEOCODER_PROVIDER=photon   # photon | google | mapbox
# GOOGLE_MAPS_API_KEY=
# MAPBOX_TOKEN=

# File storage driver — files are always served through /api/files/[...key],
# never a direct/public cloud URL, so no bucket public-access setup is needed.
# 'local' → saves to ./uploads — no credentials needed, perfect for dev
# 's3'    → generic S3-compatible (AWS S3, MinIO, DigitalOcean Spaces, ...) — fill in S3_* vars below
# 'r2'    → dedicated Cloudflare R2 — fill in R2_* vars below
STORAGE_DRIVER=local

# s3 driver — only needed when STORAGE_DRIVER=s3
# S3_ENDPOINT=          # only for non-AWS endpoints (MinIO, DO Spaces, ...)
# S3_REGION=
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# r2 driver — only needed when STORAGE_DRIVER=r2
# R2_BUCKET=your-bucket-name
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Optional for either cloud driver — a CDN/public domain bound to the bucket.
# Not required: reads always go through /api/files/[...key].
# STORAGE_PUBLIC_BASE_URL=

# White-label the product name — shown in emails, iCal PRODID, the "Powered
# by" footer, and page titles.
# NEXT_PUBLIC_PRODUCT_NAME=Schduled

# "Powered by <product>" attribution on public booking pages — on by default.
# NEXT_PUBLIC_SHOW_POWERED_BY=true

# Contact-form destination (server-only). Falls back to SMTP_USER, then a
# hardcoded address, if unset.
# CONTACT_EMAIL=

# Public-facing addresses shown on the landing/contact/privacy/cookies pages.
# NEXT_PUBLIC_CONTACT_EMAIL=support@example.com
# PRIVACY_EMAIL=privacy@example.com
