FROM node:22-bookworm-slim AS deps

WORKDIR /app

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile --prod

FROM node:22-bookworm-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Caps V8's heap so an OOM shows up as a clean, restartable crash instead of
# the container being silently killed by the host's OOM killer. Raise this if
# your container's memory limit is higher than the default assumption below.
ENV NODE_OPTIONS=--max-old-space-size=384

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
# Corepack's default cache ($HOME/.cache/node/corepack) is per-user — fine
# for whichever user runs `corepack prepare`, but the non-root `app` user
# below has no home directory, so a `pnpm` invocation as `app` would try to
# re-resolve/download into a path it can't create (EACCES). Pointing
# COREPACK_HOME at a fixed path baked into the image sidesteps that: the
# pinned pnpm release is prepared once below, as root, at build time (with
# real network access), into this shared location — any user can read it
# afterward, so `pnpm` at runtime never re-downloads or re-resolves anything.
ENV COREPACK_HOME=/opt/corepack

# package.json's "packageManager" field pins the exact pnpm version;
# `corepack prepare --activate` (no version arg) reads that pin from the
# package.json just copied in, fully resolves + caches that exact release
# into $COREPACK_HOME now, and activates it as the shim's default — so
# `pnpm` never needs to touch the network again after this layer.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json drizzle.config.ts ./
RUN corepack enable \
  && corepack prepare --activate \
  && chmod -R a+rX "$COREPACK_HOME"

RUN groupadd --system --gid 1001 app \
  && useradd --system --uid 1001 --gid app app

COPY --from=deps /app/node_modules ./node_modules
COPY config ./config
COPY db ./db
COPY lib ./lib
COPY scripts ./scripts

USER app

# Liveness signal: scripts/worker.ts writes a heartbeat file every 15s.
# Docker/Compose/k8s can't otherwise tell a wedged worker from a healthy one.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD node -e "process.exit((Date.now() - require('fs').statSync('/tmp/worker-heartbeat').mtimeMs) < 60000 ? 0 : 1)"

CMD ["pnpm", "worker:start"]
